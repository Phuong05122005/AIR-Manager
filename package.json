{
  "name": "air-components-manager-backend",
  "version": "1.0.0",
  "description": "Backend API cho AIR Components Manager",
  "main": "index.js",
  "scripts": {
    "start": "start cmd /k node server.js && expo start",
    "dev": "start cmd /k nodemon server.js && expo start -c",
    "start:prod": "node server.js",
    "expo:start": "expo start",
    "expo:android": "expo start --android",
    "expo:ios": "expo start --ios",
    "expo:web": "expo start --web",
    "build:aab": "eas build --platform android --profile production",
    "build:aab:local": "eas build --platform android --profile production --local"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/ngrok": "^4.1.3",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "axios": "^1.16.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "expo": "^54.0.34",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "express": "^4.18.2",
    "mongoose": "^8.0.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
