{
  "expo": {
    "name": "AI Robotic",
    "slug": "ai-robotic-manager",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#066071"
    },
    "extra": {
      "apiUrl": "https://air-manager-api.onrender.com/api",
      "eas": {
        "projectId": "6f5e71f6-2359-4a58-8b77-81ef21c850a9"
      }
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.air.components.manager"
    },
    "android": {
      "package": "com.air.components.manager",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#066071"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "AI Robotic cần quyền Camera để quét mã vạch linh kiện."
        }
      ]
    ]
  }
}
